# -------------------------
# Python cache / build files
# -------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pdb
*.pkl
*.so

# Byte-compiled / optimized / DLL files
*.pyc

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
venv/
.env/
.venv/
env/
ENV/

# Pytest cache
.pytest_cache/

# Coverage reports
htmlcov/
.coverage
.coverage.*
.cache

# Jupyter Notebook checkpoints (if you ever add notebooks)
.ipynb_checkpoints/

# -------------------------
# VS Code
# -------------------------
.vscode/
# (If you want to *include* settings.json in the template,
# remove .vscode/ and instead ignore only workspace-specific files)
*.code-workspace

# -------------------------
# OS-specific junk
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# Logs
# -------------------------
*.log

# -------------------------
# Tooling
# -------------------------
.mypy_cache/
.pyre/
.pytype/*
